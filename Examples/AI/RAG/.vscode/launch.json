	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Index",
			"type": "node",
			"request": "launch",
			"program": "${workspaceFolder}/out/main.js",
			"args": [ "-index" ],
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"skipFiles": [
				"<node_internals>/**"
			],
			"preLaunchTask": "Compile Smalltalk"
		},
		{
			"name": "Launch Query",
			"type": "node",
			"request": "launch",
			"program": "${workspaceFolder}/out/main.js",
			"args": "",
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"skipFiles": [
				"<node_internals>/**"
			],
			"preLaunchTask": "Compile Smalltalk"
		},
		{
			"name": "Launch Test",
			"type": "node",
			"request": "launch",
			"program": "${workspaceFolder}/out/main.js",
			"args": "-test",
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"skipFiles": [
				"<node_internals>/**"
			],
			"preLaunchTask": "Compile Smalltalk"
		}
	]
}
